# ShopReach — root env reference (optional)
# Prefer service-specific files: backend/.env and channel-service/.env

# Backend (copy to backend/.env)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
GEMINI_API_KEY=your_gemini_api_key
CHANNEL_SERVICE_URL=http://localhost:3001
PORT=3000

# Channel service (copy to channel-service/.env)
CRM_BACKEND_URL=http://localhost:3000
